{
  "name": "module-register-ponyfill",
  "version": "0.1.0",
  "description": "User-land ponyfill for module.register() built on top of module.registerHooks() + worker threads + Atomics",
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./polyfill": {
      "types": "./src/polyfill.d.ts",
      "default": "./src/polyfill.js"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "src/"
  ],
  "scripts": {
    "test": "node --test 'test/*/test.mjs'",
    "lint": "biome check",
    "lint:changed": "biome check $(git diff --name-only main --diff-filter=ACMR)",
    "lint:fix": "biome check --fix",
    "format": "biome format --write"
  },
  "engines": {
    "node": ">=22.15.0"
  },
  "keywords": [
    "module",
    "register",
    "hooks",
    "loader",
    "ponyfill",
    "esm"
  ],
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "2.4.4"
  }
}
