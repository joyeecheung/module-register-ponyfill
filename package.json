{
  "name": "module-register-ponyfill",
  "version": "0.1.0",
  "description": "User-land ponyfill for module.register() built on top of module.registerHooks() + worker threads + Atomics",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    },
    "./ponyfill": {
      "types": "./src/ponyfill.d.ts",
      "default": "./src/ponyfill.js"
    }
  },
  "files": [
    "src/"
  ],
  "scripts": {
    "test": "node --test 'test/*/test.mjs'"
  },
  "engines": {
    "node": ">=22.15.0"
  },
  "keywords": [
    "module",
    "register",
    "hooks",
    "loader",
    "ponyfill",
    "esm"
  ],
  "license": "MIT"
}
